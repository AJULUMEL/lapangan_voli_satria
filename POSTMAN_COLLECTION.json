{
  "collection": "Lapangan Voli API",
  "requests": [
    {
      "name": "Get All Lapangans",
      "method": "GET",
      "url": "http://localhost:8000/api/v1/lapangans",
      "description": "Mengambil semua data lapangan yang tersedia"
    },
    {
      "name": "Get Lapangan by ID",
      "method": "GET",
      "url": "http://localhost:8000/api/v1/lapangans/1",
      "description": "Mengambil detail lapangan berdasarkan ID"
    },
    {
      "name": "Get Jadwal",
      "method": "GET",
      "url": "http://localhost:8000/api/v1/jadwal?lapangan_id=1&tanggal=2024-12-15",
      "description": "Mengambil jadwal booking untuk lapangan tertentu di tanggal tertentu"
    },
    {
      "name": "Create Booking",
      "method": "POST",
      "url": "http://localhost:8000/api/v1/bookings",
      "headers": {
        "Content-Type": "application/json"
      },
      "body": {
        "lapangan_id": 1,
        "tanggal": "2024-12-15",
        "jam_mulai": "14:00",
        "jam_selesai": "15:00",
        "nama_penyewa": "John Doe",
        "no_hp": "08123456789",
        "keterangan": "Booking untuk latihan rutin"
      },
      "description": "Membuat booking baru"
    },
    {
      "name": "Get All Bookings",
      "method": "GET",
      "url": "http://localhost:8000/api/v1/bookings",
      "description": "Mengambil semua data booking (untuk admin)"
    },
    {
      "name": "Cancel Booking",
      "method": "PUT",
      "url": "http://localhost:8000/api/v1/bookings/1/cancel",
      "description": "Membatalkan booking berdasarkan ID"
    }
  ]
}
